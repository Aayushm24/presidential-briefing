# Copy to .env for local runs. Never commit .env.
# GitHub Actions reads these from repo secrets: Settings -> Secrets and variables -> Actions.

# =====================================================================
# Shared Atlan LLM key.
# Used by BOTH:
#   - llmproxy.atlan.dev (all Claude + Sonnet + Gemini calls)
#   - api.x.ai/v1/responses (Grok X search + freshness)
# Same value works for both endpoints.
# =====================================================================
ATLAN_LLM_KEY=                     # e.g. sk-... (from n8n "AI LLM Gateway" credential)

# =====================================================================
# Supabase (brain layer)
# =====================================================================
SUPABASE_URL=https://xbatqlzrtijdmicoakaq.supabase.co
SUPABASE_ANON_KEY=                 # Read-only via RLS. Used by daily-brief.
SUPABASE_SERVICE_KEY=              # Full access. Used ONLY by weekly-feedback workflow.

# =====================================================================
# Slack delivery (via n8n proxy, not direct Slack API)
# We POST to an n8n webhook which uses its stored "scout slack bot" credential
# to DM the user. Keeps the Slack bot token inside n8n — one place to rotate.
# Accepted payloads:
#   {"type":"nothing_new"}
#   {"type":"daily_brief","briefing_url":"...","posts":["p1","p2","p3"]}
# =====================================================================
N8N_SLACK_WEBHOOK_URL=             # https://atlanhq.app.n8n.cloud/webhook/presidential-briefing-slack
SLACK_DM_USER_ID=U08G02QDEAG       # Informational — n8n workflow is already targeted at this user

# =====================================================================
# Email delivery to Readwise Reader
# Uses Gmail SMTP + App Password (16-char string, not your account password).
# Setup:
#   1. Enable 2-Step Verification on your Google account (required for App Passwords)
#   2. Generate App Password at https://myaccount.google.com/apppasswords
#      (Select "Mail" app, any device name — generates one 16-char password)
# =====================================================================
READWISE_EMAIL=aayushm24@library.readwise.io
GMAIL_FROM_ADDRESS=                # The Gmail address sending the email (e.g., aayush.maheshwari@gmail.com)
GMAIL_APP_PASSWORD=                # 16 chars, no spaces. From https://myaccount.google.com/apppasswords

# =====================================================================
# Optional / local dev
# =====================================================================
DRY_RUN=1                          # When 1, skip Slack + Gmail + git commit
TODAY=                             # Override date for testing (YYYY-MM-DD)

# =====================================================================
# Sheets (weekly-feedback only — Week 2 scope, not needed Day 1)
# =====================================================================
SHEETS_WEBHOOK_URL=                # Google Apps Script webhook for LinkedIn analytics pull
