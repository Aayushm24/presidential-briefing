{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Write(workspace/**)",
      "Write(history/**)",
      "Write(config/conviction.md)",
      "Write(config/conviction.md.bak.*)",
      "Write(.claude/skills/write-posts/references/voice.md)",
      "Write(.claude/skills/write-posts/references/hooks.md)",
      "Edit(workspace/**)",
      "Edit(history/**)",
      "Edit(config/conviction.md)",
      "Edit(.claude/skills/write-posts/references/voice.md)",
      "Edit(.claude/skills/write-posts/references/hooks.md)",
      "Bash(git add workspace/*)",
      "Bash(git add history/*)",
      "Bash(git add config/conviction.md)",
      "Bash(git commit -m *)",
      "Bash(git push origin main)",
      "Bash(git status)",
      "Bash(git diff)",
      "Bash(git log *)",
      "Bash(date *)",
      "Bash(mkdir -p workspace/*)",
      "Bash(mkdir -p history)",
      "Bash(jq *)",
      "Bash(curl -sS -X POST https://xbatqlzrtijdmicoakaq.supabase.co/**)",
      "Bash(curl -sS -X GET https://xbatqlzrtijdmicoakaq.supabase.co/**)",
      "Bash(curl -sS -X POST https://llmproxy.atlan.dev/**)",
      "Bash(curl -sS -X POST https://api.x.ai/**)",
      "Bash(curl -sS -X POST https://slack.com/api/chat.postMessage)",
      "Bash(curl -sS -X POST https://gmail.googleapis.com/**)",
      "Bash(python3 scripts/parse_rss.py *)",
      "Bash(python3 scripts/send_gmail.py *)"
    ],
    "deny": [
      "Write(.github/**)",
      "Write(.claude/settings*.json)",
      "Write(.claude/skills/*/SKILL.md)",
      "Write(config/council.json)",
      "Write(config/sources.csv)",
      "Edit(.github/**)",
      "Edit(.claude/settings*.json)",
      "Edit(.claude/skills/*/SKILL.md)",
      "Edit(config/council.json)",
      "Edit(config/sources.csv)",
      "Bash(git push origin !(main))",
      "Bash(rm -rf *)",
      "Bash(git checkout --*)",
      "Bash(git reset --hard *)"
    ]
  },
  "env": {
    "LLM_PROXY_BASE_URL": "https://llmproxy.atlan.dev",
    "SUPABASE_URL": "https://xbatqlzrtijdmicoakaq.supabase.co",
    "GITHUB_REPO": "Aayushm24/presidential-briefing",
    "SLACK_DM_USER_ID": "U08G02QDEAG",
    "READWISE_EMAIL": "aayushm24@library.readwise.io"
  }
